// Deep Nord Aurora theme for zellij — same palette as helix / ghostty /
// yazi / oh-my-posh. RGB form is required by zellij's KDL theme schema.
//
// Hex → RGB mapping for cross-config consistency:
//   polar0 #1A1F28 → 26  31  40   (bg / black)
//   snow0  #D8DEE9 → 216 222 233  (fg)
//   snow2  #ECEFF4 → 236 239 244  (white)
//   frost1 #74BCD9 → 116 188 217  (cyan, primary accent)
//   frost3 #426F9E → 66  111 158  (blue)
//   red    #D04E5C → 208 78  92
//   green  #8DBC6E → 141 188 110
//   yellow #DDB867 → 221 184 103
//   orange #D97757 → 217 119 87
//   purple #B97AB6 → 185 122 182  (magenta)
themes {
    deep-nord-aurora {
        fg      216 222 233
        bg      26  31  40
        black   26  31  40
        red     208 78  92
        green   141 188 110
        yellow  221 184 103
        blue    66  111 158
        magenta 185 122 182
        orange  217 119 87
        cyan    116 188 217
        white   236 239 244
    }
}
