// Deep Nord Aurora zellij configuration.
// Replaces the previous tmux setup. Keybindings keep zellij's mode-based
// model AND add direct Alt-key shortcuts that mirror the previous tmux
// setup so muscle memory carries over.

// Theme inlined (block at the bottom of this file) — zellij 0.44.0 silently
// ignored external themes/*.kdl files (zellij-org/zellij#4909, fixed in
// 0.44.1). Inlining sidesteps that and keeps theme + consumer versioned
// together. `background 0` renders as ANSI default-bg (\e[49m) so ghostty's
// window transparency shows through. RGB → palette: 26,31,40 polar0 ·
// 35,41,52 polar1 · 79,88,112 polar3 · 216,222,233 snow0 · 236,239,244
// snow2 · 116,188,217 frost1 · 66,111,158 frost3 · 208,78,92 red ·
// 141,188,110 green · 221,184,103 yellow · 217,119,87 orange · 185,122,182
// purple.
theme "deep-nord-aurora"

// Skip the tip / release-notes screens that show on first launch and on
// version bumps. The user enters sessions exclusively via the `hs`
// sessionizer alias, which always invokes zellij with a session name.
show_startup_tips false
show_release_notes false

pane_frames true
rounded_corners true

default_mode "normal"
default_layout "default"

mouse_mode true
// Don't repaint pane frames when the mouse hovers — the highlight reads as
// "this pane is doing something" and competes with the focus accent.
mouse_hover_effects false
copy_command "pbcopy"
copy_on_select true
scroll_buffer_size 50000

// Detach (rather than terminate) on SIGTERM/SIGHUP so closing the Ghostty
// window leaves sessions resumable via `zellij attach`.
on_force_close "detach"

// Persist sessions (tabs, panes, cwds, running commands) so a crashed or
// closed Ghostty window can be reattached with state restored. Tradeoff:
// LSPs and editor processes get re-spawned on resurrection — fine for
// helix / yazi / shells.
session_serialization true
serialize_pane_viewport true

// Hide the session name from the pane-frame chrome — the session name is
// already in the status bar; doubling it on every frame is noise.
ui {
    pane_frames {
        hide_session_name true
    }
}

// Keybindings: keep zellij's mode-based defaults (Ctrl-p pane / Ctrl-t
// tab / Ctrl-n resize / Ctrl-s scroll / Ctrl-o session / Ctrl-g locked)
// and overlay direct Alt-key shortcuts.
keybinds {
    shared_except "locked" {
        // Tab management — direct (no mode prefix needed)
        bind "Alt t" { NewTab; }
        bind "Alt w" { CloseTab; }
        bind "Alt 1" { GoToTab 1; }
        bind "Alt 2" { GoToTab 2; }
        bind "Alt 3" { GoToTab 3; }
        bind "Alt 4" { GoToTab 4; }
        bind "Alt 5" { GoToTab 5; }
        bind "Alt 6" { GoToTab 6; }
        bind "Alt 7" { GoToTab 7; }
        bind "Alt 8" { GoToTab 8; }
        bind "Alt 9" { GoToTab 9; }
        bind "Alt [" { GoToPreviousTab; }
        bind "Alt ]" { GoToNextTab; }
        // Pane fullscreen toggle (was tmux M-f / prefix f)
        bind "Alt f" { ToggleFocusFullscreen; }
        // Toggle pane frames on/off (useful when copying with mouse)
        bind "Alt z" { TogglePaneFrames; }
        // Detach (was tmux Ctrl-q). Replaces zellij's default Quit binding
        // — Quit is destructive (closes the session entirely); detach is
        // what's wanted 95% of the time. Quit is still reachable via
        // session mode (Ctrl-o, then `q`) or Alt-q below.
        bind "Ctrl q" { Detach; }
        bind "Alt q"  { Quit; }
    }
}

themes {
    deep-nord-aurora {
        text_unselected {
            base       216 222 233
            background 0
            emphasis_0 217 119 87
            emphasis_1 116 188 217
            emphasis_2 141 188 110
            emphasis_3 185 122 182
        }
        text_selected {
            base       236 239 244
            background 35  41  52
            emphasis_0 217 119 87
            emphasis_1 116 188 217
            emphasis_2 141 188 110
            emphasis_3 185 122 182
