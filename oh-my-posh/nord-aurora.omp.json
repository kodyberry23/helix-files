{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "palette": {
    "polar0": "#1A1F28",
    "polar1": "#232934",
    "polar3": "#4F5870",
    "snow0": "#D8DEE9",
    "snow2": "#ECEFF4",
    "frost0": "#6FBAB7",
    "frost1": "#74BCD9",
    "frost2": "#5F8FBF",
    "frost3": "#426F9E",
    "red": "#D04E5C",
    "orange": "#D97757",
    "yellow": "#DDB867",
    "green": "#8DBC6E",
    "purple": "#B97AB6"
  },
  "blocks": [
    {
      "segments": [
        {
          "foreground": "p:frost2",
          "properties": {
            "time_format": "15:04:05"
          },
          "style": "plain",
          "template": " {{ .CurrentDate | date .Format }} ",
          "type": "time"
        }
      ],
      "type": "rprompt"
    },
    {
      "alignment": "left",
      "segments": [
        {
          "foreground": "p:frost1",
          "properties": {
            "style": "full"
          },
          "style": "plain",
          "template": "{{ .Path }} ",
          "type": "path"
        },
        {
          "foreground": "p:yellow",
          "properties": {
            "fetch_status": true
          },
          "style": "plain",
          "template": "{{ .HEAD }}{{ if or (.Working.Changed) (.Staging.Changed) }} ●{{ end }}{{ if gt .Behind 0 }} ⇣{{ end }}{{ if gt .Ahead 0 }} ⇡{{ end }} ",
          "type": "git"
        },
        {
          "foreground": "p:green",
          "foreground_templates": [
            "{{ if gt .Code 0 }}p:red{{ end }}"
          ],
          "properties": {
            "always_enabled": true
          },
          "style": "plain",
          "template": "❯ ",
          "type": "status"
        }
      ],
      "type": "prompt"
    }
  ],
  "final_space": true,
  "version": 4
}
